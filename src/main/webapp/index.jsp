<!DOCTYPE html>
<html>
<head>
    <title>DevOps Dashboard</title>
    <link rel="stylesheet" href="styles.css">
</head>
<body>

<div class="container">
    <h1>🚀 DevOps Dashboard</h1>
    <p>CI/CD Pipeline Project</p>

    <div class="cards">
        <div class="card success">
            <h3>Build</h3>
            <p>SUCCESS</p>
        </div>

        <div class="card info">
            <h3>Quality</h3>
            <p>PASS</p>
        </div>

        <div class="card warning">
            <h3>Deployment</h3>
            <p>RUNNING</p>
        </div>
    </div>

    <a href="status" class="btn">Check App Status</a>
</div>

</body>
</html>
